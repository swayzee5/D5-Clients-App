default_platform(:ios)

platform :ios do

  def get_api_key
    key_path = ENV["ASC_KEY_FILEPATH"]
    if key_path && File.exist?(key_path)
      app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: key_path,
        duration: 1200,
        in_house: false
      )
    else
      raise "ASC key file not found at: #{key_path}. Make sure the Prepare ASC API Key step ran."
    end
  end

  lane :init_certs do
    setup_ci if ENV["CI"]
    api_key = get_api_key
    match(
      type: "appstore",
      app_identifier: "com.dayekaba.d5coaching",
      api_key: api_key,
      readonly: false
    )
    UI.success "Certificats crees!"
  end

  lane :certificates do
    setup_ci if ENV["CI"]
    api_key = get_api_key
    match(
      type: "appstore",
      app_identifier: "com.dayekaba.d5coaching",
      api_key: api_key,
      readonly: true
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/App/App.xcodeproj",
      team_id: "PH4CLA89XR",
      bundle_identifier: "com.dayekaba.d5coaching",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore com.dayekaba.d5coaching"
    )
  end

  lane :beta do
    setup_ci if ENV["CI"]
    certificates
    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"
    increment_build_number(
      build_number: build_number,
      xcodeproj: "ios/App/App.xcodeproj"
    )
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "ios/App/build",
      output_name: "D5Coaching.ipa",
      export_options: {
        method: "app-store",
        teamID: "PH4CLA89XR",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.dayekaba.d5coaching" => "match AppStore com.dayekaba.d5coaching"
        }
      }
    )
    # Upload via xcrun altool directly with API key
    key_path = ENV["ASC_KEY_FILEPATH"]
    key_id = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]
    sh("xcrun altool --upload-app --type ios --file ios/App/build/D5Coaching.ipa --apiKey #{key_id} --apiIssuer #{issuer_id} --asc-provider PH4CLA89XR")
    UI.success "Upload TestFlight reussi!"
  end

end
