default_platform(:ios)

platform :ios do

  # --- Helpers ---

  def get_api_key
    app_store_connect_api_key(
      key_id:                  ENV["ASC_KEY_ID"],
      issuer_id:               ENV["ASC_ISSUER_ID"],
      key_content:             ENV["ASC_KEY_CONTENT"],
      is_key_content_base64:   true,
      duration:                1200,
      in_house:                false
    )
  end

  # --- Lanes ---

  desc "Creer et stocker les certificats dans d5-certs (UNE SEULE FOIS)"
  lane :init_certs do
    setup_ci if ENV["CI"]
    api_key = get_api_key
    match(
      type:                  "appstore",
      app_identifier:        "com.dayekaba.d5coaching",
      api_key:               api_key,
      readonly:              false,
      force_for_new_devices: false
    )
    UI.success "Certificats crees et stockes dans d5-certs."
  end

  desc "Recuperer les certificats depuis d5-certs (CI)"
  lane :certificates do
    setup_ci if ENV["CI"]
    api_key = get_api_key
    match(
    match(
      type:              "appstore",
      app_identifier:    "com.dayekaba.d5coaching",
      api_key:           api_key,
      readonly:          true,
      keychain_name:     "fastlane_tmp_keychain",
      keychain_password: ENV["KEYCHAIN_PASSWORD"]
    )
  end

  desc "Build Release + upload TestFlight"
  lane :beta do
    certificates

    api_key = get_api_key

    latest = begin
      latest_testflight_build_number(
        api_key:        api_key,
        app_identifier: "com.dayekaba.d5coaching"
      )
    rescue StandardError
      0
    end

    build_number = latest + 1

    increment_build_number(
      build_number: build_number,
      xcodeproj:    "ios/App/App.xcodeproj"
    )

    update_project_team(
      path:   "ios/App/App.xcodeproj",
      teamid: "PH4CLA89XR"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "ios/App/App.xcodeproj",
      team_id:               "PH4CLA89XR",
      bundle_identifier:     "com.dayekaba.d5coaching",
      profile_name:          "match AppStore com.dayekaba.d5coaching",
      code_sign_identity:    "Apple Distribution"
    )

    build_app(
      workspace:             "ios/App/App.xcworkspace",
      scheme:                "App",
      configuration:         "Release",
      export_method:         "app-store",
      output_directory:      "./build",
      output_name:           "D5Coaching",
      suppress_xcode_output: false
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      distribute_external:               false
    )

    UI.success "Build #{build_number} uploade sur TestFlight avec succes !"
  end

end
