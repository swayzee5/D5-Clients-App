require "shellwords"

def ci_keychain_name
  ENV.fetch("MATCH_KEYCHAIN_NAME", "fastlane_tmp_keychain")
end

def ci_keychain_path
  ENV["D5_KEYCHAIN_PATH"] || File.expand_path("~/Library/Keychains/#{ci_keychain_name}-db")
end

def unlock_ci_keychain
  return unless ENV["CI"]

  password = ENV["KEYCHAIN_PASSWORD"] || ENV["MATCH_KEYCHAIN_PASSWORD"]
  raise "KEYCHAIN_PASSWORD is required in CI" if password.to_s.empty?

  keychain = ci_keychain_path
  sh("security unlock-keychain -p #{Shellwords.escape(password)} #{Shellwords.escape(keychain)}")
  sh("security set-keychain-settings -lut 21600 #{Shellwords.escape(keychain)}")
  sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{Shellwords.escape(password)} #{Shellwords.escape(keychain)}")
end

def codesign_xcargs
  flags = ["-allowProvisioningUpdates"]
  flags << "OTHER_CODE_SIGN_FLAGS=\"--keychain #{ci_keychain_path}\"" if ENV["CI"]
  # iPhone only — avoids App Store rejection for missing iPad screenshots
  flags << "TARGETED_DEVICE_FAMILY='1'"
  flags.join(" ")
end

def get_api_key
  key_path = ENV.fetch("ASC_KEY_FILEPATH", "/tmp/AuthKey_N89NTU664B.p8")
  raise "ASC key file not found at: #{key_path}" unless File.exist?(key_path)
  app_store_connect_api_key(
    key_id:       ENV["ASC_KEY_ID"],
    issuer_id:    ENV["ASC_ISSUER_ID"],
    key_filepath: key_path,
    duration:     1200,
    in_house:     false
  )
end

def install_match_profile(api_key:, readonly:)
  match(
    type:              "appstore",
    app_identifier:    "com.dayekaba.d5coaching",
    api_key:           api_key,
    readonly:          readonly,
    keychain_name:     ci_keychain_name,
    keychain_password: ENV["KEYCHAIN_PASSWORD"] || ENV["MATCH_KEYCHAIN_PASSWORD"]
  )
end

def configure_app_signing
  update_project_team(
    path:   "ios/App/App.xcodeproj",
    teamid: "PH4CLA89XR"
  )

  update_code_signing_settings(
    use_automatic_signing: false,
    path:                  "ios/App/App.xcodeproj",
    team_id:               "PH4CLA89XR",
    bundle_identifier:     "com.dayekaba.d5coaching",
    profile_name:          "match AppStore com.dayekaba.d5coaching",
    code_sign_identity:    "Apple Distribution"
  )
end

def next_testflight_build_number(api_key)
  latest = begin
    latest_testflight_build_number(
      api_key:        api_key,
      app_identifier: "com.dayekaba.d5coaching"
    )
  rescue StandardError
    0
  end

  latest + 1
end

default_platform(:ios)

platform :ios do

  lane :init_certs do
    api_key = get_api_key
    install_match_profile(api_key: api_key, readonly: false)
    unlock_ci_keychain
    UI.success "Certificats crees!"
  end

  lane :certificates do
    api_key = get_api_key
    install_match_profile(api_key: api_key, readonly: true)
    unlock_ci_keychain
    UI.success "Certificats installes dans le trousseau."
  end

  lane :build_and_upload do
    api_key = get_api_key
    build_number = next_testflight_build_number(api_key)

    increment_build_number(
      build_number: build_number,
      xcodeproj:    "ios/App/App.xcodeproj"
    )

    configure_app_signing
    unlock_ci_keychain

    build_app(
      workspace:        "ios/App/App.xcworkspace",
      scheme:           "App",
      configuration:    "Release",
      sdk:              "iphoneos",
      export_method:    "app-store",
      output_directory: "ios/App/build",
      output_name:      "D5Coaching.ipa",
      xcargs:           codesign_xcargs,
      export_options:   {
        method:               "app-store",
        teamID:               "PH4CLA89XR",
        signingStyle:         "manual",
        provisioningProfiles: {
          "com.dayekaba.d5coaching" => "match AppStore com.dayekaba.d5coaching"
        }
      }
    )

    upload_to_testflight(
      api_key:                           api_key,
      app_identifier:                    "com.dayekaba.d5coaching",
      ipa:                               "ios/App/build/D5Coaching.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external:               false
    )

    UI.success "Build #{build_number} uploade sur TestFlight!"
  end

  lane :beta do
    certificates
    build_and_upload
  end

end
