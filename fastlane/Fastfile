default_platform(:ios)

platform :ios do

def get_api_key
  api_key = app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_content: ENV["ASC_KEY_CONTENT"],
    is_key_content_base64: true,
    duration: 1200,
    in_house: false
  )
  api_key
end

lane :init_certs do
  setup_ci if ENV["CI"]
  api_key = get_api_key
  match(
    type: "appstore",
    app_identifier: "com.dayekaba.d5coaching",
    api_key: api_key,
    readonly: false
  )
  UI.success "Certificats crees!"
end

lane :certificates do
  setup_ci if ENV["CI"]
  api_key = get_api_key
  match(
    type: "appstore",
    app_identifier: "com.dayekaba.d5coaching",
    api_key: api_key,
    readonly: true
  )
end

lane :beta do
  setup_ci if ENV["CI"]
  certificates
  build_number = ENV["GITHUB_RUN_NUMBER"] || "1"
  increment_build_number(
    build_number: build_number,
    xcodeproj: "ios/App/App.xcodeproj"
  )
  build_app(
    workspace: "ios/App/App.xcworkspace",
    scheme: "App",
    configuration: "Release",
    export_method: "app-store",
    output_directory: "ios/App/build",
    output_name: "D5Coaching.ipa"
  )
  api_key = get_api_key
  upload_to_testflight(
    api_key: api_key,
    app_identifier: "com.dayekaba.d5coaching",
    ipa: "ios/App/build/D5Coaching.ipa",
    skip_waiting_for_build_processing: true
  )
  UI.success "Upload TestFlight reussi!"
end

end
